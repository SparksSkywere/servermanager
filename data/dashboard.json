{
  "configuration": {
    "debugMode": false,
    "offlineMode": false,
    "hideServerConsoles": true,
    "systemRefreshInterval": 4,
    "processMonitoringInterval": 5,
    "maxProcessHistoryPoints": 20,
    "networkUpdateInterval": 5,
    "serverListUpdateInterval": 30,
    "systemInfoUpdateInterval": 5,
    "processMonitorUpdateInterval": 10,
    "webserverStatusUpdateInterval": 15
  },
  "runtime": {
    "formDisplayed": false,
    "verificationInProgress": false,
    "webserverStatus": "Disconnected"
  },
  "defaults": {
    "minecraftServersPath": "minecraft_servers",
    "otherServersPath": "other_servers",
    "logRetentionDays": 30,
    "maxLogFileSize": 10485760,
    "autoStartServers": false,
    "enableNotifications": true
  },
  "ui": {
    "windowWidth": 1200,
    "windowHeight": 700,
    "minWindowWidth": 800,
    "minWindowHeight": 600,
    "theme": "default",
    "showAdvancedOptions": false,
    "autoRefresh": true
  },
  "logging": {
    "maxLogFiles": 10,
    "logLevel": "INFO",
    "enableFileLogging": true,
    "enableConsoleLogging": true,
    "logFormat": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}